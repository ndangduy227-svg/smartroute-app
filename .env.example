# === SERVER-SIDE ONLY (never exposed to browser) ===

PORT=3000

# Firebase Project ID (required for backend auth token verification)
FIREBASE_PROJECT_ID=

# TrackAsia API Key - used by backend for VRP + Geocoding
# Get from: https://track-asia.com/
TRACK_ASIA_API_KEY=

# Lark/Feishu Integration
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_ID=
LARK_TABLE_ID=
LARK_ROUTES_TABLE_ID=

# POSCake (Pancake) Integration
POSCAKE_API_KEY=
POSCAKE_SHOP_ID=

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === FRONTEND (VITE_ prefix = embedded in browser JS bundle) ===
# WARNING: These values are PUBLIC. Only put non-secret config here.

# TrackAsia Map Key - for map tile rendering ONLY
# IMPORTANT: Restrict this key to your production domain on TrackAsia dashboard
VITE_TRACK_ASIA_API_KEY=

# Firebase Web App Config (these are public by design)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
